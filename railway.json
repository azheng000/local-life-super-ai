{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nix_dependencies": {}
        },
        "install": {
          "commands": [
            "npm install"
          ],
          "priority": 0
        },
        "build": {
          "commands": [
            "npm run build"
          ],
          "priority": 10
        }
      },
      "start": {
        "command": "npm start",
        "inputVariables": []
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckConfig": {
      "path": "/health",
      "port": 3001,
      "intervalSeconds": 30,
      "timeoutSeconds": 10
    }
  }
}
